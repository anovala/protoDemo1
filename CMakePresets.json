{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS" : "ON",
                "VCPKG_MANIFEST_MODE" : "ON",
                "CMAKE_BUILD_TYPE" : "Debug"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Ninja Debug",
            "inherits" : "base",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE" :"/home/sola/opensrc/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET" : "x64-linux"
            }
        },
        {
            "name": "windows-debug",
            "displayName": "Windows MSVC Ninja Debug",
            "inherits" : "base",
            "architecture" : { "value": "x64", "strategy": "external"},
            "toolset" : {"value": "host=x64", "strategy": "external"},
            "cacheVariables": {
                "CMAKE_C_COMPILER" : "cl",
                "CMAKE_CXX_COMPILER" : "cl",
                "CMAKE_TOOLCHAIN_FILE" : "C:/Users/38614/opensrc/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET" : "x64-windows"
            }
        },
        {
            "name": "qt-windows-debug",
            "displayName": "Qt Vscode MSVC Debug",
            "inherits" : "windows-debug",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "QT_CREATOR_SPECIFIC" : "ON",
                "CMAKE_TOOLCHAIN_FILE" : "C:/Qt/6.8.3/msvc2022_64/lib/cmake/Qt6/qt.toolchain.cmake",
                "QT_CHAINLOAD_TOOLCHAIN_FILE" : "C:/Users/38614/opensrc/vcpkg/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "qtcreator-windows-debug",
            "displayName": "Qt Creator MSVC Debug",
            "inherits" : "windows-debug",
            "binaryDir": "${sourceDir}/qtcreator-build",
            "cacheVariables": {
                "QT_CREATOR_SPECIFIC" : "ON"
            }
        }
    ]
}